{
  "$schema": "appsettings-schema.json",
  "ConnectionStrings": {
    "umbracoDbDSN_ProviderName": "System.Data.SqlClient"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "ef9daa04-3381-433d-b23d-7f8675d4babe",
        "SanitizeTinyMce": true,
        "MainDomLock": "SqlMainDomLock"
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Security": {
        "AllowConcurrentLogins": false
      },
      "HealthChecks" : {
        "DisabledChecks": [
          {
            "Id": "E2048C48-21C5-4BE1-A80B-8062162DF124" // HstsCheck
          }
        ]
      }
    }
  },
  "uSync": {
    "Settings": {
      "ExportOnSave" : "Settings"
    },
    "Sets": {
      "Default": {
        "HandlerDefaults": {
          "UseFlatStructure": true,
          "GuidNames": true
        }
      }
    }
  }
}
